
        /* Entry animation for Rayon Vert Camera Pan (Return from Guide) */
        @keyframes cameraPanUp {
            0% {
                transform: perspective(1000px) rotateX(30deg) translateY(-10%);
                width: 120%; left: -10%;
            }
            100% {
                transform: perspective(800px) rotateX(70deg) translateY(0);
                width: 60%; left: 20%;
            }
        }
        @keyframes planetDescend {
            0% { top: -30%; transform: translate(calc(var(--cam-x) * 0.6), calc(var(--cam-y) * 0.6)) scale(1.5); opacity: 0.3; }
            100% { top: 50%; transform: translate(calc(var(--cam-x) * 0.6), calc(var(--cam-y) * 0.6)) scale(1); opacity: 1; }
        }
        @keyframes ceilingDescend {
            0% { top: -15%; }
            100% { top: 0; }
        }

        body[data-theme="rayon"] .cockpit-frame::before,
        body[data-theme="rayon"] .cockpit-frame::after {
            animation: cameraPanUp 1.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }
        body[data-theme="rayon"] .planet-atmosphere,
        body[data-theme="rayon"] .sun-eclipse {
            animation: planetDescend 1.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }
        body[data-theme="rayon"] .cockpit-ceiling {
            animation: ceilingDescend 1.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }
